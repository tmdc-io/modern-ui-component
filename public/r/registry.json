{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "modernui",
  "homepage": "https://github.com/your-org/ModernUIComponent",
  "items": [
    {
      "name": "theme",
      "type": "registry:theme",
      "title": "ModernUI Theme",
      "description": "Design tokens, CSS variables, and base styles for ModernUI.",
      "files": [
        {
          "path": "registry/default/theme/globals.css",
          "type": "registry:theme",
          "target": "app/globals.css"
        }
      ]
    },
    {
      "name": "utils",
      "type": "registry:lib",
      "title": "Utils",
      "description": "Utility helpers including the cn() classname merger.",
      "dependencies": ["clsx", "tailwind-merge"],
      "files": [
        {
          "path": "lib/utils.ts",
          "type": "registry:lib",
          "target": "lib/utils.ts"
        }
      ]
    },
    {
      "name": "button",
      "type": "registry:ui",
      "title": "Button",
      "description": "ModernUI button with brand variants.",
      "dependencies": ["@radix-ui/react-slot", "class-variance-authority"],
      "registryDependencies": ["utils"],
      "files": [
        {
          "path": "registry/default/ui/button.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "input",
      "type": "registry:ui",
      "title": "Input",
      "description": "ModernUI text input primitive.",
      "registryDependencies": ["utils"],
      "files": [
        {
          "path": "registry/default/ui/input.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "card",
      "type": "registry:ui",
      "title": "Card",
      "description": "ModernUI card layout primitive.",
      "registryDependencies": ["utils"],
      "files": [
        {
          "path": "registry/default/ui/card.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "label",
      "type": "registry:ui",
      "title": "Label",
      "description": "ModernUI form label primitive.",
      "dependencies": ["@radix-ui/react-label"],
      "registryDependencies": ["utils"],
      "files": [
        {
          "path": "registry/default/ui/label.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "dialog",
      "type": "registry:ui",
      "title": "Dialog",
      "description": "ModernUI modal dialog primitive.",
      "dependencies": ["radix-ui", "lucide-react"],
      "registryDependencies": ["utils", "button"],
      "files": [
        {
          "path": "registry/default/ui/dialog.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "login-form",
      "type": "registry:block",
      "title": "Login Form",
      "description": "A sign-in form with Zod validation and ModernUI brand styling.",
      "dependencies": ["zod"],
      "registryDependencies": ["button", "input", "label", "card"],
      "files": [
        {
          "path": "registry/default/blocks/login-form/login-form.tsx",
          "type": "registry:component"
        }
      ]
    },
    {
      "name": "project-setup",
      "type": "registry:item",
      "title": "Project Setup",
      "description": "Shared project conventions and agent instructions for ModernUI projects.",
      "files": [
        {
          "path": "AGENTS.md",
          "type": "registry:file",
          "target": "~/AGENTS.md"
        },
        {
          "path": "docs/CONSUMER.md",
          "type": "registry:file",
          "target": "~/docs/modernui-setup.md"
        }
      ]
    }
  ]
}
